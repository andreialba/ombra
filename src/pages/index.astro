---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import { siteConfig } from "../config/site";
import chefImage from "../assets/chef.png";
import conceptImage from "../assets/concept.png";
import detailImage from "../assets/detail.png";
import heroImage from "../assets/hero.webp";
import interiorImage from "../assets/interior.png";
import menuImage from "../assets/menu.webp";
import wineImage from "../assets/wine.png";

const marquee = [
  "Embers",
  "Ash Butter",
  "Night Herbs",
  "Fermentation",
  "Wild Orchard",
  "Charred Citrus",
  "Cellar Smoke",
  "Tidewater",
  "Old Grain",
  "Candle Wax",
];

const courses = [
  {
    number: "I",
    title: "First Light",
    accent: "of the orchard",
    body: "Quince, raw cream, bitter almond, a whisper of smoke from the morning's first coals.",
    pairing: "Cider - Asturias, 2022",
  },
  {
    number: "II",
    title: "Tide",
    accent: "after the storm",
    body: "Day-boat langoustine, fennel pollen, the brine of its own shell reduced to glass.",
    pairing: "Albarino - Rias Baixas, 2021",
  },
  {
    number: "III",
    title: "The Ember",
    accent: "kept overnight",
    body: "Heirloom beet buried in ash since dawn, aged sheep's butter, sourdough crust.",
    pairing: "Trousseau - Jura, 2020",
  },
  {
    number: "IV",
    title: "An Animal,",
    accent: "patiently",
    body: "Forty-day lamb shoulder cooked beside the fire, charred allium, fermented plum.",
    pairing: "Mencia - Bierzo, 2018",
  },
  {
    number: "V",
    title: "Field, Burnt",
    accent: "and cooled",
    body: "Toasted grain ice, hazelnut praline, a cold pour of single-estate olive oil.",
    pairing: "PX - Montilla, 1998",
  },
  {
    number: "VI",
    title: "Last Word",
    body: "Bitter chocolate, fig leaf, salt from the cliffs at Llanes.",
    pairing: "Genever - house infusion",
  },
];

const timeline = [
  { year: "1986", text: "Born in Pollenzo, between vineyards and his grandmother's hearth." },
  { year: "2008", text: "Stages at Mugaritz and Etxebarri. Learns the discipline of fire." },
  { year: "2014", text: "Opens Ombra with twelve seats and no sign on the door." },
  { year: "2019", text: "First star. Refuses to expand. Closes Sundays and Mondays." },
  { year: "2024", text: "Second star. Same twelve seats. Same fire." },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  name: siteConfig.name,
  description: siteConfig.description,
  url: new URL(Astro.url.pathname, Astro.site ?? siteConfig.url).href,
  image: new URL("/og.png", Astro.site ?? siteConfig.url).href,
  telephone: siteConfig.phone,
  email: siteConfig.email,
  servesCuisine: ["Italian", "Seasonal tasting menu", "Wood-fired"],
  priceRange: "EUR245",
  address: {
    "@type": "PostalAddress",
    streetAddress: siteConfig.address.street,
    addressLocality: siteConfig.address.locality,
    postalCode: siteConfig.address.postalCode,
    addressCountry: siteConfig.address.country,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Wednesday", "Thursday", "Friday", "Saturday"],
      opens: "19:30",
      closes: "23:45",
    },
  ],
};
---

<BaseLayout image="/og.png" structuredData={structuredData}>
  <Nav />

  <main id="main">
    <section id="top" class="hero" aria-labelledby="hero-title">
      <Image
        class="media-fill"
        src={heroImage}
        alt="Chef hands finishing a small ceramic plate beside a live wood fire"
        width={1024}
        height={1536}
        quality={92}
        loading="eager"
        decoding="sync"
      />
      <div class="overlay" style="background: var(--grad-vignette);"></div>
      <div class="overlay" style="background: var(--grad-veil);"></div>
      <div class="hero-content">
        <div class="hero-grid">
          <div class="hero-heading">
            <p class="label-eyebrow reveal">Tasting Counter - Twelve Seats</p>
            <h1 id="hero-title" class="hero-title display reveal reveal-delay-1">
              We cook<br />
              <span class="display-italic" style="color: var(--ember);">with the dark</span><br />
              and a little fire.
            </h1>
          </div>

          <div class="hero-copy reveal reveal-delay-2">
            <p>
              Ombra is a counter for twelve, hidden behind an unmarked door in the old quarter.
              One menu. One season. One fire at the centre of the room.
            </p>
            <div class="hero-actions">
              <a class="button-link" href="#reserve">Reserve a seat <span aria-hidden="true">-&gt;</span></a>
            </div>
          </div>
        </div>
      </div>

    </section>

    <section class="marquee" aria-label="Ombra values">
      <div class="marquee-track">
        {[...marquee, ...marquee].map((item) => (
          <span>
            {item}
            <b aria-hidden="true">✦</b>
          </span>
        ))}
      </div>
    </section>

    <section id="concept" class="section concept-section">
      <div class="container section-grid">
        <div class="section-kicker">
          <p class="label-eyebrow reveal">01 - Concept</p>
        </div>
        <h2 class="section-heading display reveal">
          A room held together<br />
          <span class="display-italic" style="color: var(--ember);">by heat,</span> by hands,<br />
          by the quiet between courses.
        </h2>

        <div class="text-block reveal reveal-delay-1">
          <p>
            We do not write a menu. We listen to the week: to the market, the boats, the orchard
            outside town, and we cook what is most alive that night. The fire is the only constant.
          </p>
          <p>
            Service is slow on purpose. Twelve guests, one pass, one pace. You will meet the cooks,
            watch the embers fall, and stay for three hours without noticing.
          </p>
        </div>

        <figure class="figure-detail reveal">
          <div class="image-frame aspect-3-4">
            <Image
              src={detailImage}
              alt="Handmade ceramic bowl with a small seasonal tasting course"
              width={1200}
              height={1500}
              loading="lazy"
            />
          </div>
          <figcaption class="label-eyebrow" style="margin-top: 1rem;">Fig. 01 - Vessel, raku, 2026</figcaption>
        </figure>

        <div class="fire-block reveal">
          <div class="fire-media image-frame aspect-16-10">
            <Image
              src={conceptImage}
              alt="Glowing embers and flame in a working restaurant hearth"
              width={1400}
              height={875}
              loading="lazy"
            />
          </div>
          <div class="quote-block">
            <blockquote>"The fire is older than the recipe. We only translate."</blockquote>
            <p class="label-eyebrow" style="margin-top: 1.5rem;">- Elia Marchetti, Chef</p>
          </div>
        </div>
      </div>
    </section>

    <section id="menu" class="section surface-section">
      <div class="container section-grid">
        <div class="section-kicker">
          <p class="label-eyebrow reveal">02 - Tasting</p>
        </div>
        <h2 class="section-heading display reveal">
          Six movements,<br />
          <span class="display-italic" style="color: var(--ember);">one evening,</span><br />
          written that morning.
        </h2>

        <aside class="menu-aside reveal" aria-label="Menu notes">
          <div class="image-frame aspect-3-4">
            <Image
              src={menuImage}
              alt="Seasonal ingredients laid out before service on a dark stone prep counter"
              width={1200}
              height={1500}
              loading="lazy"
            />
          </div>
          <p class="label-eyebrow" style="margin-top: 1rem;">Mise - week 47</p>
          <div class="hairline" style="margin-block: 2rem 1.5rem;"></div>
          <p style="color: var(--muted-foreground); line-height: 1.6;">
            EUR245 per guest, six courses. Wine pairing EUR165, non-alcoholic EUR85.
            Service begins at 19:30, sharp.
          </p>
        </aside>

        <ol class="course-list">
          {courses.map((course) => (
            <li class="course reveal">
              <span class="course-number">{course.number}</span>
              <h3>{course.title} {course.accent && <span class="display-italic">{course.accent}</span>}</h3>
              <p>{course.body}</p>
              <span class="pairing">{course.pairing}</span>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section id="chef" class="section">
      <div class="container section-grid">
        <div class="section-kicker">
          <p class="label-eyebrow reveal">03 - The Chef</p>
        </div>
        <h2 class="section-heading display reveal">
          Elia Marchetti.<br />
          <span class="display-italic" style="color: var(--ember);">A quiet cook,</span> a patient room.
        </h2>

        <div class="chef-media image-frame aspect-4-5 reveal">
          <Image
            src={chefImage}
            alt="Black and white candid portrait of Chef Elia Marchetti in profile"
            width={1200}
            height={1500}
            loading="lazy"
          />
        </div>

        <div class="chef-bio reveal reveal-delay-1">
          <p class="chef-quote">
            "I learned to cook from my grandmother, who never owned a thermometer and never made
            the same dish twice."
          </p>
          <div class="hairline" style="margin-block: 2.5rem;"></div>
          <ul class="timeline">
            {timeline.map((row) => (
              <li>
                <time datetime={row.year}>{row.year}</time>
                <span>{row.text}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section id="interior" class="surface-section">
      <div class="interior-hero">
        <Image
          src={interiorImage}
          alt="Twelve-seat tasting counter with terracotta plaster walls, oak beams, candles, and an open hearth"
          width={1800}
          height={1200}
          loading="lazy"
        />
        <div class="overlay" style="background: var(--grad-veil);"></div>
        <div class="interior-caption">
          <p class="label-eyebrow">04 - Sala</p>
          <h2 class="display">
            Terracotta walls, <span class="display-italic" style="color: var(--ember);">one candle,</span>
            oak older than the city.
          </h2>
        </div>
      </div>

      <div class="container section">
        <div class="feature-grid">
          <section>
            <p class="label-eyebrow">Materials</p>
            <p>Hand-troweled lime plaster in burnt sienna. Reclaimed oak beams from a 17th-century granary. Cast iron, smoked glass, raw linen.</p>
          </section>
          <section>
            <p class="label-eyebrow">Light</p>
            <p>Two sources only: the hearth at the centre of the counter, and a single tall taper at each setting. The room is never brighter than the food.</p>
          </section>
          <section>
            <p class="label-eyebrow">Sound</p>
            <p>A custom playlist by composer Luis Tinoco. Strings, breath, the long pause. No screens, no notifications, no announcements.</p>
          </section>
        </div>
      </div>
    </section>

    <section id="reserve" class="section reservation">
      <Image
        class="reservation-bg"
        src={wineImage}
        alt=""
        width={900}
        height={1200}
        loading="lazy"
        aria-hidden="true"
      />
      <div class="overlay" style="background: var(--grad-vignette);"></div>

      <div class="container section-grid">
        <div class="reservation-copy">
          <p class="label-eyebrow reveal">05 - Reserve</p>
          <h2 class="display reveal">
            Twelve seats.<br />
            <span class="display-italic" style="color: var(--ember);">Two seatings.</span><br />
            One evening at a time.
          </h2>
          <p class="reveal reveal-delay-1">
            Bookings open the first Monday of each month for the following month. A deposit of
            EUR100 per guest secures your seat and is fully credited to your bill.
          </p>
          <div class="reservation-facts reveal reveal-delay-2">
            <div>
              <p class="label-eyebrow">Service</p>
              <p>Wed - Sat<br />19:30 and 21:45</p>
            </div>
            <div>
              <p class="label-eyebrow">Quiet days</p>
              <p>Sun, Mon, Tue</p>
            </div>
          </div>
        </div>

        <form class="reservation-form reveal" action={siteConfig.reservation.formAction} method={siteConfig.reservation.method} enctype="text/plain">
          <p class="label-eyebrow">Request a table</p>
          <div class="form-grid">
            <div class="form-field--full">
              <label class="label-eyebrow" for="name">Full name <span aria-hidden="true">*</span></label>
              <input id="name" name="name" autocomplete="name" required />
            </div>
            <div>
              <label class="label-eyebrow" for="email">Email <span aria-hidden="true">*</span></label>
              <input id="email" name="email" type="email" autocomplete="email" required />
            </div>
            <div>
              <label class="label-eyebrow" for="phone">Phone</label>
              <input id="phone" name="phone" type="tel" autocomplete="tel" />
            </div>
            <div>
              <label class="label-eyebrow" for="date">Date <span aria-hidden="true">*</span></label>
              <input id="date" name="date" type="date" required />
            </div>
            <div>
              <label class="label-eyebrow" for="guests">Guests</label>
              <select id="guests" name="guests">
                {["2", "3", "4", "5", "6"].map((option) => <option value={option}>{option}</option>)}
              </select>
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="time">Seating</label>
              <select id="time" name="time">
                {["19:30", "21:45"].map((option) => <option value={option}>{option}</option>)}
              </select>
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="occasion">Special occasion</label>
              <select id="occasion" name="occasion">
                {["None", "Anniversary", "Birthday", "Engagement", "Just because"].map((option) => (
                  <option value={option}>{option}</option>
                ))}
              </select>
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="note">A note for the kitchen</label>
              <textarea id="note" name="note" rows="3" placeholder="Allergies, dietary needs, anything we should know."></textarea>
            </div>
          </div>
          <button class="form-button" type="submit">Request seat <span aria-hidden="true">-&gt;</span></button>
          <p style="color: var(--muted-foreground); font-size: 0.85rem;">We confirm every request personally within 24 hours.</p>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
